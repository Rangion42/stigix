#!/bin/sh
# =============================================================================
# Stigix Secret Guard — Git Pre-Commit Hook
# Blocks commits containing Palo Alto SASE credentials or similar secrets.
# =============================================================================

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

FOUND=0

echo ""
echo "🔐 Stigix Secret Guard — scanning staged files for credentials..."

# -------------------------------------------------------------------
# Pattern 1 — Palo Alto service account ID
# Matches: something@numbers.iam.panserviceaccount.com
# -------------------------------------------------------------------
MATCHES=$(git diff --cached -U0 | grep "+" | grep -E "[a-zA-Z0-9._+-]+@[0-9]+\.iam\.panserviceaccount\.com")
if [ -n "$MATCHES" ]; then
    echo ""
    printf "${RED}🚨 BLOCKED — Palo Alto service account ID detected:${NC}\n"
    echo "$MATCHES" | head -5
    FOUND=1
fi

# -------------------------------------------------------------------
# Pattern 2 — Palo Alto / OAuth client secret (real UUID value)
# Matches: CLIENT_SECRET="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
# Excludes: placeholder values like "your-client-secret", "xxx", "..."
# -------------------------------------------------------------------
MATCHES=$(git diff --cached -U0 | grep "+" | grep -E "(CLIENT_SECRET|client_secret)\s*[=:]\s*[\"']?[a-f0-9]{8}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{12}[\"']?")
if [ -n "$MATCHES" ]; then
    echo ""
    printf "${RED}🚨 BLOCKED — Client secret (UUID format) detected:${NC}\n"
    echo "$MATCHES" | head -5
    FOUND=1
fi

# -------------------------------------------------------------------
# Pattern 3 — TSG ID with real numeric value (7+ digits)
# Matches: PRISMA_SDWAN_TSGID=1234567890
# Excludes: TSGID=your-tsgid, TSGID=<tsgid>
# -------------------------------------------------------------------
MATCHES=$(git diff --cached -U0 | grep "+" | grep -E "PRISMA_SDWAN_TSGID\s*=\s*[0-9]{7,}" | grep -v "your-\|<\|example\|placeholder")
if [ -n "$MATCHES" ]; then
    echo ""
    printf "${YELLOW}⚠️  WARNING — Prisma TSG ID (real numeric value) detected:${NC}\n"
    echo "$MATCHES" | head -5
    printf "${YELLOW}   TSG ID alone is not secret but combined with other credentials it reveals your tenant.${NC}\n"
    # TSG ID alone is not a secret — warn but don't block
fi

# -------------------------------------------------------------------
# Pattern 4 — credentials.json.old / *.env.old / backup files tracked
# -------------------------------------------------------------------
CRED_FILES=$(git diff --cached --name-only | grep -E "\.(old|bak|backup)$|credentials\..*\.(json|env|txt)$")
if [ -n "$CRED_FILES" ]; then
    echo ""
    printf "${RED}🚨 BLOCKED — Backup/old credential files being committed:${NC}\n"
    echo "$CRED_FILES"
    printf "${RED}   These files often contain real values copied from active configs.${NC}\n"
    FOUND=1
fi

# -------------------------------------------------------------------
# Pattern 5 — Generic: private key header
# -------------------------------------------------------------------
MATCHES=$(git diff --cached -U0 | grep "+" | grep -E "BEGIN (RSA |EC |OPENSSH )?PRIVATE KEY")
if [ -n "$MATCHES" ]; then
    echo ""
    printf "${RED}🚨 BLOCKED — Private key content detected:${NC}\n"
    echo "$MATCHES" | head -3
    FOUND=1
fi

# -------------------------------------------------------------------
# Result
# -------------------------------------------------------------------
if [ "$FOUND" -eq 1 ]; then
    echo ""
    printf "${RED}╔══════════════════════════════════════════════════════════╗${NC}\n"
    printf "${RED}║  COMMIT BLOCKED by Stigix Secret Guard                  ║${NC}\n"
    printf "${RED}║  Remove credentials before committing.                   ║${NC}\n"
    printf "${RED}║  If this is a false positive, use:                      ║${NC}\n"
    printf "${RED}║    git commit --no-verify                                ║${NC}\n"
    printf "${RED}╚══════════════════════════════════════════════════════════╝${NC}\n"
    echo ""
    exit 1
else
    printf "${GREEN}✅ No credentials detected — commit allowed.${NC}\n"
    echo ""
    exit 0
fi
